# IoTSpy NAS Configuration
# Populated automatically by install.sh on first install.
# Edit these values to customize your deployment.

# ── Required ──────────────────────────────────────────────────────────────────
# JWT signing secret — must be at least 32 characters.
# Generated automatically. Do not share or commit this value.
AUTH_JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# ── Optional ──────────────────────────────────────────────────────────────────
# Docker image version to run. Update this value and restart to upgrade
# without reinstalling the full APK.
#   latest    — always use the most recent image (default)
#   1.2.3     — pin to a specific release
IOTSPY_VERSION=latest

# Hostname or IP address of this NAS.
# Used to generate correct links in the IoTSpy UI.
# Leave as 'localhost' if you only access IoTSpy from the NAS itself.
NAS_HOST=localhost

# ── Networking note ───────────────────────────────────────────────────────────
# By default docker-compose.nas.yml uses network_mode: host so that
# IoTSpy can intercept traffic at the link layer (transparent proxy, ARP spoof).
# If you only need the explicit HTTP/HTTPS proxy (port 8888), you can switch to
# bridge mode by editing docker-compose.yml and uncommenting the ports section.
