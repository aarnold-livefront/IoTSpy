{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "IoTSpy": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "sqlite",
    "ConnectionString": "Data Source=iotspy.db",
    "MaxPoolSize": 20,
    "MinPoolSize": 1
  },
  "Auth": {
    "JwtSecret": "CHANGE_ME_BEFORE_FIRST_RUN_minimum_32_chars",
    "PasswordHash": ""
  },
  "Frontend": {
    "Origin": "http://localhost:3000"
  },
  "Urls": "http://*:5000",
  "Kestrel": {
    "Certificate": {
      "Path": "",
      "Password": ""
    },
    "LetsEncrypt": {
      "Enabled": false,
      "Email": "",
      "Domain": "",
      "UseStagingServer": false,
      "CertificatePath": "/data/certs/iotspy-le.pfx",
      "CertificatePassword": ""
    }
  },
  "Plugins": {
    "Directory": "plugins"
  },
  "Resilience": {
    "ConnectTimeoutSeconds": 15,
    "TlsHandshakeTimeoutSeconds": 10,
    "RetryCount": 2,
    "RetryBaseDelaySeconds": 0.5,
    "CircuitBreakerFailureRatio": 0.5,
    "CircuitBreakerSamplingSeconds": 30,
    "CircuitBreakerBreakSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "IoTSpy": "Debug"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/iotspy-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "RateLimit": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 10
  },
  "Alerting": {
    "Enabled": false,
    "Webhook": {
      "Url": "",
      "Secret": ""
    },
    "Email": {
      "SmtpHost": "",
      "SmtpPort": 587,
      "From": "",
      "To": "",
      "Username": "",
      "Password": ""
    },
    "Slack": {
      "WebhookUrl": "",
      "Channel": ""
    },
    "Teams": {
      "WebhookUrl": ""
    },
    "PagerDuty": {
      "IntegrationKey": "",
      "MinimumSeverity": "Critical"
    }
  },
  "Redis": {
    "ConnectionString": "",
    "KeyPrefix": "iotspy",
    "PassiveBufferCapacity": 10000,
    "EnableSignalRBackplane": true
  },
  "DataRetention": {
    "Enabled": false,
    "CaptureRetentionDays": 30,
    "PacketRetentionDays": 7,
    "ScanJobRetentionDays": 90,
    "OpenRtbEventRetentionDays": 14,
    "RunIntervalHours": 24
  }
}
